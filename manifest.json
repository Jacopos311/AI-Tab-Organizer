{
  "manifest_version": 3,
  "name": "AI Tab Organizer",
  "version": "1.0.0",
  "description": "Organize your browser tabs intelligently using AI. Group, sort, and manage tabs with ease.",
  "author": "Your Name or Organization",
  "homepage_url": "https://github.com/your-username/ai-tab-organizer",

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Tab Organizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "tabs",
    "tabGroups",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },

  "minimum_chrome_version": "102"
}